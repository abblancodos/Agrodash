{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            b.id      AS box_id,\n            b.name    AS box_name,\n            s.id      AS \"sensor_id?: uuid::Uuid\",\n            s.sensor_number AS \"sensor_number?: i32\",\n            s.type    AS \"sensor_type?: String\"\n        FROM boxes b\n        LEFT JOIN sensors s ON s.box_id = b.id\n        ORDER BY b.name, s.sensor_number, s.type\n        ",
